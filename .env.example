# SecurePulse Environment Variables

# 1. PostgreSQL Database Credentials
POSTGRES_USER=securepulse_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=telemetry

# 2. Application Secrets
SESSION_SECRET=replace-with-a-long-random-string

# Note: The connection string (DATABASE_URL) is automatically generated in docker-compose.yml using the POSTGRES_ variables.
